## Vercel Postgres — ejemplo local alineado a producción

# Preferida para tooling/migraciones/tests locales
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# URL pooled usada habitualmente por la app en Vercel
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Fallback estándar para librerías/herramientas
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Opcional: variables por partes si no querés usar URL completa
# POSTGRES_HOST="HOST"
# POSTGRES_PORT="5432"
# POSTGRES_USER="USER"
# POSTGRES_PASSWORD="PASSWORD"
# POSTGRES_DATABASE="DATABASE"

# Auth / app
AUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"
